# Wallet Connect
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Local contract addresses (deployed via forge)
VITE_ENABLE_LOCAL_NETWORK=false
VITE_TANGLE_CONTRACT=0x0000000000000000000000000000000000000000
VITE_SANDBOX_BSM=0x0000000000000000000000000000000000000000
VITE_INSTANCE_BSM=0x0000000000000000000000000000000000000000
VITE_TEE_INSTANCE_BSM=0x0000000000000000000000000000000000000000

# Base Sepolia contract addresses
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_BASE_SEPOLIA_TANGLE_CONTRACT=0x8299d60f373f3a4a8c4878e335cb9d840e6e3730
VITE_BASE_SEPOLIA_SANDBOX_BSM=0x281d2d1160d80070ebe8989a529b6732c8403625
VITE_BASE_SEPOLIA_INSTANCE_BSM=0xde25dad1757e5dab5230d44779d7de6ad8181c5c
VITE_BASE_SEPOLIA_TEE_INSTANCE_BSM=0x6d6debfa88260558597ad912439ea1949962b3eb
VITE_BASE_SEPOLIA_SANDBOX_BLUEPRINT_ID=10
VITE_BASE_SEPOLIA_INSTANCE_BLUEPRINT_ID=11
VITE_BASE_SEPOLIA_TEE_INSTANCE_BLUEPRINT_ID=12
VITE_BASE_SEPOLIA_SANDBOX_SERVICE_ID=1
VITE_BASE_SEPOLIA_INSTANCE_SERVICE_ID=2
VITE_BASE_SEPOLIA_TEE_INSTANCE_SERVICE_ID=

# Local blueprint and service IDs (read only when VITE_ENABLE_LOCAL_NETWORK=true)
VITE_SANDBOX_BLUEPRINT_ID=1
VITE_INSTANCE_BLUEPRINT_ID=2
VITE_TEE_INSTANCE_BLUEPRINT_ID=3
VITE_SANDBOX_SERVICE_ID=1
VITE_INSTANCE_SERVICE_ID=2

# Operator API (provision progress, session auth, sandbox listing)
VITE_OPERATOR_API_URL=http://localhost:9090
VITE_INSTANCE_OPERATOR_API_URL=http://localhost:9200

# Testnet contract addresses
VITE_TESTNET_SANDBOX_BSM=0x0000000000000000000000000000000000000000
VITE_TESTNET_INSTANCE_BSM=0x0000000000000000000000000000000000000000
VITE_TESTNET_TEE_INSTANCE_BSM=0x0000000000000000000000000000000000000000
VITE_TESTNET_JOBS_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TESTNET_SERVICES_ADDRESS=0x0000000000000000000000000000000000000000

# Mainnet contract addresses
VITE_MAINNET_SANDBOX_BSM=0x0000000000000000000000000000000000000000
VITE_MAINNET_INSTANCE_BSM=0x0000000000000000000000000000000000000000
VITE_MAINNET_TEE_INSTANCE_BSM=0x0000000000000000000000000000000000000000
