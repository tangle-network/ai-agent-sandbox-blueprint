# Generated by Cargo
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Project configuration
.idea
.vscode
.zed

.direnv
.DS_Store
# Solc Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Dotenv file
.env
.env.local
ui/.env.local

# Generated blueprint files
blueprint.json
blueprint.lock

# Soldeer dependencies
dependencies/

# Runtime state (test artifacts)
blueprint-state/
**/blueprint-state/

# Deploy script data (keystores, state)
scripts/data/

# UI build artifacts
ui/build/
ui/.react-router/
ui/node_modules/

# Playwright E2E
ui/test-results/
ui/playwright-report/
ui/e2e-results/

# Playwright MCP
.playwright-mcp

# Monorepo workspace (pnpm hoisted)
node_modules/
packages/*/node_modules/
packages/*/dist/

# AI
.agent-memory
agent-results
